# Copy to .env.local for `vercel dev` (gitignored). Mirror these in the
# Vercel dashboard (Project → Settings → Environment Variables) for deploys.
RESEND_API_KEY=re_your_key_here
CONTACT_TO=developer@tegrach-nigeria.com
CONTACT_FROM=Tegrach Nigeria <website@tegrach-nigeria.com>
# Optional — enables Turnstile verification. Cloudflare always-pass TEST secret below.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# Optional — overrides the auto-detected site URL used for the email logo.
# SITE_URL=https://tegrach-nigeria.com
